# kunkun 配置示例 —— 复制成 .env 并填入你自己的 API Key
# ⚠️ 分发给别人时：绝不要带上你自己填好 Key 的 .env，只带这个 .example

# DeepSeek（主脑，纯文本）—— 去 https://platform.deepseek.com 用自己账号申请
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
MODEL_ID=deepseek-v4-pro

# 小米 MiMo（看图，多模态）—— 去 https://platform.xiaomimimo.com 用小米账号申请
# 注意：能看图的是 mimo-v2.5，别填成纯文本的 mimo-v2.5-pro
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL_ID=mimo-v2.5
