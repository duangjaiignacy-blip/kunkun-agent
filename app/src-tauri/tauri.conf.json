{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kunkun",
  "version": "0.1.0",
  "identifier": "cool.kunkun.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5180",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "kunkun",
        "url": "index.html?win=pet",
        "width": 470,
        "height": 440,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focusable": false,
        "acceptFirstMouse": true,
        "visibleOnAllWorkspaces": true,
        "visible": true
      },
      {
        "label": "panel",
        "title": "kunkun 面板",
        "url": "index.html?win=panel",
        "width": 980,
        "height": 720,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "maximizable": false,
        "minimizable": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
